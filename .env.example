DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/losscontrol?schema=public"
DEFAULT_USER_EMAIL="admin@empresa.com"

# Bucket GCS para imagens. Se vazio, salva local em /uploads.
STORAGE_IMAGE=""
# Opcional: domínio/base público para montar URL final dos arquivos.
STORAGE_PUBLIC_BASE_URL=""

# Limites HTTP
JSON_LIMIT="8mb"
RATE_LIMIT_WINDOW_MS="60000"
RATE_LIMIT_MAX="120"
